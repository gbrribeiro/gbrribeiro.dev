<!--Scripts-->
<script>
    //Menu logic 
    var menu = document.getElementById('menu-list');

    window.addEventListener('click', function (e) {
        if (window.getComputedStyle(menu).opacity == '1') {
            if (!menu.contains(e.target)) {
                closeMenu();
            }
        }
    });
    function goToProjects() {
        closeMenu();
        goToPage(2);
    }

    function goToContacts() {
        closeMenu();
        goToPage(3);
    }

    function closeMenu() {
        menu.classList.remove("open-menu");
        menu.classList.add("close-menu");
    }

    function openMenu() {
        menu.classList.remove("close-menu");
        menu.classList.add("open-menu");
    }

    //Scroll logic
    var currentPage = 0;
    document.getElementById("page-" + currentPage + "-content").scrollIntoView();

    var maxPages = document.getElementsByClassName("page").length;

    function goToNextPage() {
        var lastPage = currentPage;
        if (currentPage < (maxPages - 1)) {
            currentPage++;
            var activePage = currentPage;
            activatePageDot(lastPage, activePage);
            document.getElementById("page-" + currentPage + "-content").scrollIntoView();
        }
    }

    function goToPreviousPage() {
        var lastPage = currentPage;
        if (currentPage > 0) {
            currentPage--;
            var activePage = currentPage;
            activatePageDot(lastPage, activePage);
            document.getElementById("page-" + currentPage + "-content").scrollIntoView();
        }
    }
    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }
    var isScrolling = false;
    $(document).bind('mousewheel', function (e) {
        if (!isScrolling) {
            isScrolling = true;

            var delta = e.originalEvent.wheelDelta;

            if (delta < 0) {
                goToNextPage();
            }
            if (delta > 0) {
                goToPreviousPage();
            }

            setTimeout(function () {
                isScrolling = false;
            }, 1000); // Set the timeout to 1000 milliseconds (1 second)
        }
    });

    //Typed Logic
    var typed = new Typed(".auto-type", {
        strings: ['Full-Stack', 'Back-End', 'Front-End', 'Mobile'],
        typeSpeed: 50,
        backSpeed: 50,
        backDelay: 5000,
        loop: true
    });

    var typedProjects = new Typed(".auto-type-projects", {
        strings: ['Projects.'],
        typeSpeed: 300,
        loop: false
    });

    //Cards logic
    var cards = document.getElementsByClassName("card-obj");
    if (cards.length > 4) {

        for (var i = 0; i < cards.length; i++) {
            cards[i].classList.remove("mx-auto");
            cards[i].classList.add("mx-2");
        }
    }
    //Scrollbar logic

    function activatePageDot(oldPage, activePage) {
        var elements = document.getElementsByClassName("scrollbar-dot");
        elements[oldPage].classList.remove("current-active");
        elements[oldPage].classList.add("current-unactive");
        elements[activePage].classList.remove("current-unactive");
        elements[activePage].classList.add("current-active");
    }

    function goToPage(pageNumber) {
        activatePageDot(currentPage, pageNumber);
        currentPage = pageNumber;
        document.getElementById("page-" + pageNumber + "-content").scrollIntoView();
    }

</script>